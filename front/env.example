# ==============================
# EAM - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ==============================

# --- FRONTEND (Vite) ---
# URL du backend en développement (déjà géré par le proxy Vite)
VITE_API_URL=http://localhost:3001/api
VITE_SOCKET_URL=http://localhost:3001

# URL du backend pour le build natif (APK / Android).
# Si vide, Android remplacera localhost par 10.0.2.2 pour l'emulateur.
# Pour un vrai telephone, utilisez une URL publique HTTPS.
VITE_NATIVE_API_URL=
VITE_NATIVE_SOCKET_URL=

# --- BACKEND (Express) ---
NODE_ENV=development
PORT=3001

# JWT - Changer cette clé secrète en production !
JWT_SECRET=eam_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Base de donnees MongoDB (Prisma provider = mongodb)
# Exemple local:
# DATABASE_URL="mongodb://127.0.0.1:27017/eam"
# Exemple Atlas:
# DATABASE_URL="mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/eam?retryWrites=true&w=majority"
DATABASE_URL="mongodb://127.0.0.1:27017/eam"

# Demarrage du backend si DB injoignable:
# - false: demarre en mode degrade (dev)
# - true:  stoppe le serveur si la DB est KO (prod recommande)
DB_REQUIRED_ON_STARTUP=false

# CORS - Origines autorisées (séparées par virgule)
CORS_ORIGINS=http://localhost:5173

# --- PRODUCTION (Railway + Vercel) ---
# DATABASE_URL="mongodb://127.0.0.1:27017/eam"
# CORS_ORIGINS=https://eam.vercel.app

# Adaptive lesson/exercise engine
ADAPTIVE_COURS_ENABLED=true
